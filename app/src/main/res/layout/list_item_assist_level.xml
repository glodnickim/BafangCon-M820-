<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/levelRowRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_level_card"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp">

    <TextView
        android:id="@+id/levelTitleBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:textSize="120sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:alpha="0.3"
        tools:text="E" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/assistLevelLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/assist_level"
            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/assistLevelEdit"
                android:layout_width="40dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_edit_text"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="3"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="35" />

            <TextView
                android:id="@+id/assistLevelMinusBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_btn_round"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="-"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.slider.Slider
                android:id="@+id/assistLevelSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0"
                android:valueTo="100"
                android:stepSize="1"
                app:labelBehavior="gone"
                app:thumbColor="@color/slider_orange"
                app:trackColorActive="@color/slider_orange"
                app:trackColorInactive="#FFD5B3"
                tools:value="35" />

            <TextView
                android:id="@+id/assistLevelPlusBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_btn_round"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/motorPowerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/motor_power_limit"
            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/motorPowerEdit"
                android:layout_width="40dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_edit_text"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="3"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="50" />

            <TextView
                android:id="@+id/motorPowerMinusBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_btn_round"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="-"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.slider.Slider
                android:id="@+id/motorPowerSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0"
                android:valueTo="100"
                android:stepSize="1"
                app:labelBehavior="gone"
                app:thumbColor="@color/slider_orange"
                app:trackColorActive="@color/slider_orange"
                app:trackColorInactive="#FFD5B3"
                tools:value="50" />

            <TextView
                android:id="@+id/motorPowerPlusBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_btn_round"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
